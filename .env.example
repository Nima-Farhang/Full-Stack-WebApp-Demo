# Local development defaults for Docker Compose and GitHub Codespaces.
# Copy this file to .env before running docker compose locally.

stage=build

POSTGRES_DB=backend-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Optional for local development. Leave blank unless you have a Sentry project.
sentry_dsn=
